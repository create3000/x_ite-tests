{
  "name": "x_ite-tests",
  "version": "1.0.0",
  "description": "Unit Tests for X_ITE",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:release": "vitest --run --bail=1",
    "test:docs": "perl tests/node/docs/documentation.pl",
    "test:x3duom": "node tests/node/docs/x3duom.js > tests/node/docs/x3duom.txt"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/create3000/unit-tests.git"
  },
  "author": "Holger Seelig",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/create3000/unit-tests/issues"
  },
  "homepage": "https://github.com/create3000/unit-tests#readme",
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@vitest/browser-playwright": "^4.1.10",
    "fast-xml-parser": "^5.10.1",
    "shell-tools": "^1.1.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
